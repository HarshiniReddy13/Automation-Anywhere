# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# ---------------------------------------------------------------------------

# Target environment: dev | staging | prod  (selects a block in config/environment.ts)
TEST_ENV=dev

# Base URL of the Automation Anywhere Community Edition instance
BASE_URL=https://community.cloud.automationanywhere.digital

# Credentials
AA_USERNAME=your.username@example.com
AA_PASSWORD=your-password

# Optional runtime overrides
HEADLESS=true
# Bumped generously: the live Community Edition backend has shown 5-8s+
# post-login bootstrap time and occasional slow responses under load, so
# tight timeouts produce false "failures" that are really just slowness.
DEFAULT_TIMEOUT=60000
ACTION_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
EXPECT_TIMEOUT=20000

# NOTE: do not set CI here. Any value (even "false") makes process.env.CI a
# non-empty string, which playwright.config.ts treats as truthy and enables
# CI-mode retries/workers. Leave CI unset locally; real CI systems set it
# to "true" automatically.
