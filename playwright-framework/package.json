{
  "name": "playwright-framework",
  "version": "1.0.0",
  "description": "Production-ready Playwright + TypeScript UI automation framework (POM) for Automation Anywhere Community Edition",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:rules": "playwright test tests/rulesBuilder.spec.ts",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "codegen": "playwright codegen",
    "install:browsers": "playwright install --with-deps"
  },
  "keywords": ["playwright", "typescript", "automation", "pom", "sdet"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.6.0"
  }
}
